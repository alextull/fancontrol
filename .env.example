ZWIFT_USERNAME=your_zwift_email@example.com
ZWIFT_PASSWORD=your_zwift_password
ZWIFT_PLAYER_ID=your_player_id

# Zwift simulation mode: speed thresholds (km/h) to switch fan levels
SPEED_LEVEL1=10
SPEED_LEVEL2=30
SPEED_LEVEL3=40

# Zwift workout mode: minimum heartrate to activate fan
HEARTRATE=125
# Power thresholds (watts) to switch fan levels
POWER_LEVEL1=150
POWER_LEVEL2=195
POWER_LEVEL3=265

# Particle Cloud log forwarding (Option 1 — see README Security section)
# Set all three to enable forwarding of Photon log events to the Node.js logger.
# PARTICLE_DEVICE_ID    — 24-char hex device ID from console.particle.io
# PARTICLE_ACCESS_TOKEN — API user token for the product (created under
#                         console.particle.io > your product > API Users)
# PARTICLE_PRODUCT_ID   — product ID or slug visible in the console URL:
#                         console.particle.io/{product-slug}/devices
#                         e.g. my-fancontrol-43693
#                         Required when using an API user token; the product
#                         event stream endpoint is the only SSE endpoint that
#                         API user tokens are permitted to call.
PARTICLE_DEVICE_ID=
PARTICLE_ACCESS_TOKEN=
PARTICLE_PRODUCT_ID=

# Photon shared secret — set a random string here and the matching value in
# fancontroller.ino (HOST_SECRET). Requests to /getFanLevel without this
# header will be rejected with 403. Leave empty to disable the check (dev only).
PHOTON_SECRET=

# Logging
# Log level: debug | info | warn | error  (default: info)
LOG_LEVEL=info
# Optional path for log file output (leave empty to log to console only)
# Example: LOG_FILE=logs/fancontrol.log
LOG_FILE=
